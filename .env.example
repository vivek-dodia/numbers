# ── Personal API key (primary — the app auto-loads from this on start) ───────
# Get it from intervals.icu → Settings → Developer. Basic auth uses username
# "API_KEY" and this value as the password. Kept server-side only; never sent
# to the browser.
INTERVALS_API_KEY=your_api_key_here
ATHLETE_ID=i000000

# ── intervals.icu OAuth credentials (optional) ───────────────────────────────
# Leave blank to use the API key above. Register an app by emailing
# david@intervals.icu (app name, description, website URL, square 128x128+ logo
# URL, privacy policy URL, redirect URI, and your athlete ID). http://localhost
# redirects are always allowed during development.
INTERVALS_CLIENT_ID=
INTERVALS_CLIENT_SECRET=
REDIRECT_URI=http://localhost:3001/auth/callback
INTERVALS_SCOPES=ACTIVITY:READ,WELLNESS:READ,SETTINGS:READ

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Long random string used to sign the session cookie. Change this.
SESSION_SECRET=change_me_to_a_long_random_string
# Where the browser loads the app from in dev (Vite). Used for redirects.
CLIENT_ORIGIN=http://localhost:5173
